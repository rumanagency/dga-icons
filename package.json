{
  "name": "dga-icons",
  "private": true,
  "version": "0.0.0",
  "description": "A comprehensive icon library with 4,354 icons in 9 styles",
  "scripts": {
    "generate": "node scripts/generate-core.mjs && node scripts/generate-react.mjs && node scripts/generate-vue.mjs && node scripts/generate-js.mjs",
    "generate:core": "node scripts/generate-core.mjs",
    "generate:react": "node scripts/generate-react.mjs",
    "build": "NODE_OPTIONS=--max_old_space_size=8192 pnpm -r build",
    "build:core": "pnpm --filter @dga-icons/core build",
    "build:react": "pnpm --filter @dga-icons/react build",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "icons",
    "svg",
    "react",
    "components",
    "ui"
  ],
  "author": "Saleh @ Ruman",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "devDependencies": {
    "@types/react-dom": "^19.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}

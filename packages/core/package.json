{
  "name": "@dga-icons/core",
  "version": "0.1.0",
  "description": "Icon data for DGA Icons — 4,354 icons in 9 styles",
  "license": "ISC",
  "author": "Saleh @ Ruman",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./icons/*": {
      "import": {
        "types": "./dist/esm/icons/*.d.ts",
        "default": "./dist/esm/icons/*.js"
      },
      "require": {
        "types": "./dist/cjs/icons/*.d.cts",
        "default": "./dist/cjs/icons/*.cjs"
      }
    },
    "./stroke-rounded": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./solid-rounded": {
      "import": {
        "types": "./dist/esm/solid-rounded/index.d.ts",
        "default": "./dist/esm/solid-rounded/index.js"
      }
    },
    "./solid-rounded/icons/*": {
      "import": {
        "types": "./dist/esm/solid-rounded/icons/*.d.ts",
        "default": "./dist/esm/solid-rounded/icons/*.js"
      }
    },
    "./bulk-rounded": {
      "import": {
        "types": "./dist/esm/bulk-rounded/index.d.ts",
        "default": "./dist/esm/bulk-rounded/index.js"
      }
    },
    "./bulk-rounded/icons/*": {
      "import": {
        "types": "./dist/esm/bulk-rounded/icons/*.d.ts",
        "default": "./dist/esm/bulk-rounded/icons/*.js"
      }
    },
    "./duotone-rounded": {
      "import": {
        "types": "./dist/esm/duotone-rounded/index.d.ts",
        "default": "./dist/esm/duotone-rounded/index.js"
      }
    },
    "./duotone-rounded/icons/*": {
      "import": {
        "types": "./dist/esm/duotone-rounded/icons/*.d.ts",
        "default": "./dist/esm/duotone-rounded/icons/*.js"
      }
    },
    "./twotone-rounded": {
      "import": {
        "types": "./dist/esm/twotone-rounded/index.d.ts",
        "default": "./dist/esm/twotone-rounded/index.js"
      }
    },
    "./twotone-rounded/icons/*": {
      "import": {
        "types": "./dist/esm/twotone-rounded/icons/*.d.ts",
        "default": "./dist/esm/twotone-rounded/icons/*.js"
      }
    },
    "./solid-sharp": {
      "import": {
        "types": "./dist/esm/solid-sharp/index.d.ts",
        "default": "./dist/esm/solid-sharp/index.js"
      }
    },
    "./solid-sharp/icons/*": {
      "import": {
        "types": "./dist/esm/solid-sharp/icons/*.d.ts",
        "default": "./dist/esm/solid-sharp/icons/*.js"
      }
    },
    "./solid-standard": {
      "import": {
        "types": "./dist/esm/solid-standard/index.d.ts",
        "default": "./dist/esm/solid-standard/index.js"
      }
    },
    "./solid-standard/icons/*": {
      "import": {
        "types": "./dist/esm/solid-standard/icons/*.d.ts",
        "default": "./dist/esm/solid-standard/icons/*.js"
      }
    },
    "./stroke-sharp": {
      "import": {
        "types": "./dist/esm/stroke-sharp/index.d.ts",
        "default": "./dist/esm/stroke-sharp/index.js"
      }
    },
    "./stroke-sharp/icons/*": {
      "import": {
        "types": "./dist/esm/stroke-sharp/icons/*.d.ts",
        "default": "./dist/esm/stroke-sharp/icons/*.js"
      }
    },
    "./stroke-standard": {
      "import": {
        "types": "./dist/esm/stroke-standard/index.d.ts",
        "default": "./dist/esm/stroke-standard/index.js"
      }
    },
    "./stroke-standard/icons/*": {
      "import": {
        "types": "./dist/esm/stroke-standard/icons/*.d.ts",
        "default": "./dist/esm/stroke-standard/icons/*.js"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "icons",
    "svg",
    "icon-data",
    "dga-icons"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/dga-icons",
    "directory": "packages/core"
  }
}
